{
  "manifest_version": 3,
  "name": "AO3 Tracker Griyo Edition",
  "version": "1.3",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://archiveofourown.org/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {
    "default_title": "AO3 Tracker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://archiveofourown.org/*"],
      "css": ["interfaz/style.css"],
      "js": ["ui_logic.js", "content_script.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "interfaz/notificaciones.html",
        "interfaz/seguidos.html",
        "interfaz/configuracion.html",
        "interfaz/style.css",
        "ui_logic.js"
      ],
      "matches": ["https://archiveofourown.org/*"]
    }
  ]
}